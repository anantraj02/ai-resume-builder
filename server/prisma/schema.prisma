generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  resumes   Resume[]
}

model Resume {
  id         String   @id @default(cuid())
  title      String
  summary    String
  skills     String
  experience String
  education  String
  projects   String

  atsScore   Int      @default(0)

  createdAt  DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}
